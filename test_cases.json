{
  "kanban": [
    [
      "has_columns",
      "document.querySelectorAll('.column, [class*=column], [class*=Column]').length >= 3 || document.querySelectorAll('[class*=todo], [class*=progress], [class*=done]').length >= 3"
    ],
    [
      "has_tasks",
      "document.querySelectorAll('.task, [class*=task], [class*=card], [class*=item]').length > 0 || document.querySelectorAll('li').length > 0"
    ],
    [
      "dark_theme",
      "const bg = getComputedStyle(document.body).backgroundColor; const rgb = bg.match(/\\d+/g); rgb && (parseInt(rgb[0]) + parseInt(rgb[1]) + parseInt(rgb[2])) / 3 < 80"
    ],
    [
      "has_button",
      "document.querySelectorAll('button').length > 0"
    ],
    [
      "has_input",
      "document.querySelectorAll('input, textarea').length > 0"
    ],
    [
      "has_drag",
      "typeof document.querySelectorAll('[draggable]')[0] !== 'undefined' || document.querySelectorAll('[draggable=true]').length > 0 || typeof document.ondragstart !== 'undefined'"
    ],
    [
      "has_search",
      "document.querySelectorAll('input[type=text], input[type=search], input[placeholder*=search], input[placeholder*=Search]').length > 0"
    ],
    [
      "responsive",
      "document.querySelectorAll('style').length > 0 && document.body.innerHTML.includes('@media')"
    ],
    [
      "localStorage_used",
      "document.body.innerHTML.includes('localStorage') || document.querySelectorAll('script').length > 0 && Array.from(document.querySelectorAll('script')).some(s => s.textContent.includes('localStorage'))"
    ],
    [
      "has_priority",
      "document.body.innerHTML.match(/priority|high|medium|low/i) !== null"
    ]
  ],
  "dashboard": [
    [
      "has_kpi_cards",
      "document.querySelectorAll('.card, [class*=card], [class*=kpi], [class*=stat]').length >= 3"
    ],
    [
      "has_chart",
      "document.querySelector('canvas') !== null || document.querySelectorAll('svg').some(s => s.querySelectorAll('rect,line,path,circle').length > 5)"
    ],
    [
      "dark_theme",
      "const bg = getComputedStyle(document.body).backgroundColor; const rgb = bg.match(/\\d+/g); rgb && (parseInt(rgb[0]) + parseInt(rgb[1]) + parseInt(rgb[2])) / 3 < 80"
    ],
    [
      "has_data",
      "document.body.innerHTML.match(/\\$|revenue|user|order|growth|sales|profit/i) !== null"
    ],
    [
      "has_list",
      "document.querySelectorAll('li, [class*=item], [class*=row], [class*=feed]').length >= 5"
    ],
    [
      "has_button",
      "document.querySelectorAll('button').length > 0"
    ],
    [
      "responsive",
      "document.body.innerHTML.includes('@media')"
    ],
    [
      "has_hover",
      "document.body.innerHTML.includes(':hover')"
    ],
    [
      "has_animation",
      "document.body.innerHTML.includes('transition') || document.body.innerHTML.includes('animation') || document.body.innerHTML.includes('@keyframes')"
    ],
    [
      "has_numbers",
      "document.body.innerHTML.match(/\\d+[,.]?\\d*\\s*[%KMB$]/) !== null"
    ]
  ],
  "chess": [
    [
      "has_board",
      "document.querySelectorAll('td, [class*=square], [class*=cell]').length >= 32 || document.querySelectorAll('[class*=board] *').length >= 32"
    ],
    [
      "has_pieces",
      "document.body.innerHTML.match(/[\u2654\u2655\u2656\u2657\u2658\u2659\u265a\u265b\u265c\u265d\u265e\u265f]/) !== null"
    ],
    [
      "dark_theme",
      "const bg = getComputedStyle(document.body).backgroundColor; const rgb = bg.match(/\\d+/g); rgb && (parseInt(rgb[0]) + parseInt(rgb[1]) + parseInt(rgb[2])) / 3 < 80"
    ],
    [
      "has_newgame",
      "document.body.innerHTML.match(/new game|restart|reset/i) !== null"
    ],
    [
      "click_handler",
      "document.body.innerHTML.includes('onclick') || document.body.innerHTML.includes('click') || document.body.innerHTML.includes('addEventListener')"
    ],
    [
      "turn_indicator",
      "document.body.innerHTML.match(/turn|white|black|move/i) !== null"
    ],
    [
      "has_move_history",
      "document.body.innerHTML.match(/history|moves|log/i) !== null"
    ],
    [
      "has_captured",
      "document.body.innerHTML.match(/captured|taken/i) !== null"
    ],
    [
      "responsive",
      "document.body.innerHTML.includes('@media') || document.body.innerHTML.includes('viewport')"
    ],
    [
      "has_64_squares",
      "document.querySelectorAll('td, [class*=square], [class*=cell]').length >= 64"
    ]
  ],
  "markdown": [
    [
      "has_textarea",
      "document.querySelectorAll('textarea').length > 0"
    ],
    [
      "has_preview",
      "document.body.innerHTML.match(/preview|output|result/i) !== null"
    ],
    [
      "dark_theme",
      "const bg = getComputedStyle(document.body).backgroundColor; const rgb = bg.match(/\\d+/g); rgb && (parseInt(rgb[0]) + parseInt(rgb[1]) + parseInt(rgb[2])) / 3 < 80"
    ],
    [
      "split_layout",
      "document.body.innerHTML.includes('flex') || document.body.innerHTML.includes('grid') || document.querySelectorAll('textarea').length > 0 && document.querySelectorAll('[class*=preview], [class*=output], [id*=preview], [id*=output]').length > 0"
    ],
    [
      "has_toolbar",
      "document.querySelectorAll('button').length >= 3"
    ],
    [
      "parses_bold",
      "const ta = document.querySelector('textarea'); ta && (ta.value.includes('**') || ta.value.includes('__') || ta.value.includes('*'))"
    ],
    [
      "parses_heading",
      "const ta = document.querySelector('textarea'); ta && (ta.value.includes('#') || ta.value.includes('##'))"
    ],
    [
      "has_wordcount",
      "document.body.innerHTML.match(/word|count|character/i) !== null"
    ],
    [
      "has_copy",
      "document.body.innerHTML.match(/copy|clipboard/i) !== null"
    ],
    [
      "responsive",
      "document.body.innerHTML.includes('@media')"
    ]
  ],
  "calculator": [
    [
      "has_buttons",
      "document.querySelectorAll('button').length >= 10"
    ],
    [
      "has_display",
      "document.querySelectorAll('[class*=display], [class*=screen], [class*=result], [class*=output]').length > 0 || document.querySelectorAll('input').length > 0"
    ],
    [
      "dark_theme",
      "const bg = getComputedStyle(document.body).backgroundColor; const rgb = bg.match(/\\d+/g); rgb && (parseInt(rgb[0]) + parseInt(rgb[1]) + parseInt(rgb[2])) / 3 < 80"
    ],
    [
      "has_numbers",
      "document.body.innerHTML.match(/[0-9]/) !== null && document.querySelectorAll('button').length >= 10"
    ],
    [
      "has_operators",
      "document.body.innerHTML.match(/[+\\-*/=]/) !== null"
    ],
    [
      "has_clear",
      "document.body.innerHTML.match(/C|CE|clear|clear/i) !== null"
    ],
    [
      "grid_layout",
      "document.body.innerHTML.includes('grid')"
    ],
    [
      "keyboard_support",
      "document.body.innerHTML.includes('keydown') || document.body.innerHTML.includes('keyboard') || document.body.innerHTML.includes('addEventListener')"
    ],
    [
      "memory_funcs",
      "document.body.innerHTML.match(/M\\+|M-|MR|MC|memory/i) !== null"
    ],
    [
      "responsive",
      "document.body.innerHTML.includes('@media') || document.body.innerHTML.includes('viewport')"
    ]
  ],
  "snake": [
    [
      "has_canvas",
      "document.querySelectorAll('canvas').length > 0"
    ],
    [
      "dark_theme",
      "const bg = getComputedStyle(document.body).backgroundColor; const rgb = bg.match(/\\d+/g); rgb && (parseInt(rgb[0]) + parseInt(rgb[1]) + parseInt(rgb[2])) / 3 < 80"
    ],
    [
      "has_score",
      "document.body.innerHTML.match(/score|point/i) !== null"
    ],
    [
      "has_controls",
      "document.body.innerHTML.includes('keydown') || document.body.innerHTML.includes('ArrowUp') || document.body.innerHTML.includes('arrow')"
    ],
    [
      "game_loop",
      "document.body.innerHTML.includes('requestAnimationFrame') || document.body.innerHTML.includes('setInterval') || document.body.innerHTML.includes('setTimeout')"
    ],
    [
      "collision",
      "document.body.innerHTML.match(/collision|game.?over|gameover/i) !== null"
    ],
    [
      "restart",
      "document.body.innerHTML.match(/restart|play.?again|new.?game|start/i) !== null"
    ],
    [
      "food",
      "document.body.innerHTML.match(/food|apple|eat/i) !== null"
    ],
    [
      "speed_increase",
      "document.body.innerHTML.match(/speed|level|difficulty|interval/i) !== null"
    ],
    [
      "high_score",
      "document.body.innerHTML.match(/high.?score|best|record/i) !== null"
    ]
  ],
  "pomodoro": [
    [
      "has_timer",
      "document.body.innerHTML.match(/25|timer|minute|countdown/i) !== null"
    ],
    [
      "has_controls",
      "document.querySelectorAll('button').length >= 2"
    ],
    [
      "dark_theme",
      "const bg = getComputedStyle(document.body).backgroundColor; const rgb = bg.match(/\\d+/g); rgb && (parseInt(rgb[0]) + parseInt(rgb[1]) + parseInt(rgb[2])) / 3 < 80"
    ],
    [
      "has_svg_progress",
      "document.querySelectorAll('svg').length > 0 || document.querySelectorAll('circle').length > 0 || document.querySelectorAll('[class*=progress], [class*=ring]').length > 0"
    ],
    [
      "has_modes",
      "document.body.innerHTML.match(/work|break|short|long/i) !== null"
    ],
    [
      "session_count",
      "document.body.innerHTML.match(/session|round|cycle/i) !== null"
    ],
    [
      "audio_beep",
      "document.body.innerHTML.includes('AudioContext') || document.body.innerHTML.includes('OscillatorNode') || document.body.innerHTML.includes('beep') || document.body.innerHTML.includes('play')"
    ],
    [
      "start_pause",
      "document.body.innerHTML.match(/start|pause|resume|stop/i) !== null"
    ],
    [
      "settings",
      "document.body.innerHTML.match(/setting|custom|duration|config/i) !== null"
    ],
    [
      "responsive",
      "document.body.innerHTML.includes('@media')"
    ]
  ],
  "weather": [
    [
      "has_temp",
      "document.body.innerHTML.match(/\\d+\u00b0|\u00b0C|\u00b0F|celsius|fahrenheit|temperature/i) !== null"
    ],
    [
      "has_forecast",
      "document.body.innerHTML.match(/forecast|5.?day|weekly|daily/i) !== null"
    ],
    [
      "dark_theme",
      "const bg = getComputedStyle(document.body).backgroundColor; const rgb = bg.match(/\\d+/g); rgb && (parseInt(rgb[0]) + parseInt(rgb[1]) + parseInt(rgb[2])) / 3 < 80"
    ],
    [
      "has_svg_chart",
      "document.querySelectorAll('svg').length > 0 || document.body.innerHTML.match(/chart|graph|plot/i) !== null"
    ],
    [
      "has_icons",
      "document.querySelectorAll('svg').length > 0 || document.body.innerHTML.match(/sun|cloud|rain|weather/i) !== null"
    ],
    [
      "humidity_wind",
      "document.body.innerHTML.match(/humidity|wind|pressure/i) !== null"
    ],
    [
      "toggle_units",
      "document.body.innerHTML.match(/celsius|fahrenheit|\u00b0C|\u00b0F|toggle|unit/i) !== null"
    ],
    [
      "responsive",
      "document.body.innerHTML.includes('@media')"
    ],
    [
      "has_sunrise",
      "document.body.innerHTML.match(/sunrise|sunset|dawn|dusk/i) !== null"
    ],
    [
      "has_air_quality",
      "document.body.innerHTML.match(/air.?quality|aqi|pollution/i) !== null"
    ]
  ],
  "password": [
    [
      "has_slider",
      "document.querySelectorAll('input[type=range]').length > 0"
    ],
    [
      "has_toggles",
      "document.querySelectorAll('input[type=checkbox]').length >= 2"
    ],
    [
      "dark_theme",
      "const bg = getComputedStyle(document.body).backgroundColor; const rgb = bg.match(/\\d+/g); rgb && (parseInt(rgb[0]) + parseInt(rgb[1]) + parseInt(rgb[2])) / 3 < 80"
    ],
    [
      "has_display",
      "document.body.innerHTML.match(/password|generated/i) !== null"
    ],
    [
      "has_copy",
      "document.body.innerHTML.match(/copy|clipboard/i) !== null"
    ],
    [
      "strength_meter",
      "document.body.innerHTML.match(/strength|weak|strong|meter/i) !== null"
    ],
    [
      "generate_button",
      "document.querySelectorAll('button').length > 0"
    ],
    [
      "entropy",
      "document.body.innerHTML.match(/entropy|bits|random/i) !== null"
    ],
    [
      "history",
      "document.body.innerHTML.match(/history|previous|last/i) !== null"
    ],
    [
